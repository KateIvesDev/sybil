# Sybil — database connection
#
# Two ways to connect (see src/db/index.ts). Default is direct TCP via `pg`;
# set USE_DATA_API=true to use the RDS Data API instead.
#
# ── Option A (default): direct TCP ───────────────────────────────────────────
# Point DATABASE_URL at a Postgres endpoint. Used for local dev, for `pnpm
# db:seed`, and for the app's direct-to-Aurora path.
#
#   Local docker:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sybil"
#
#   Aurora (cluster endpoint, TLS). Use sslmode=no-verify, NOT require: newer `pg`
#   treats `require` as full cert verification, which fails on the RDS CA chain
#   (UNABLE_TO_GET_ISSUER_CERT_LOCALLY). no-verify stays encrypted, skips CA check.
#   DATABASE_URL="postgresql://sybil_admin:PASS@sybil-aurora.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/sybil?sslmode=no-verify"
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sybil"

# ── Option B: RDS Data API (HTTPS + IAM, no open 5432) ───────────────────────
# The secure path for Vercel → private Aurora. Set USE_DATA_API=true and supply
# the values below (all are `terraform output`s). Keep seeding on Option A — the
# Data API is slow for bulk inserts. Leave USE_DATA_API unset for local dev.
USE_DATA_API=""
RDS_RESOURCE_ARN=""              # terraform output rds_cluster_arn
RDS_SECRET_ARN=""                # terraform output secrets_manager_secret_arn
RDS_DATABASE="sybil"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""             # terraform output data_api_access_key_id
AWS_SECRET_ACCESS_KEY=""         # terraform output -raw data_api_secret_access_key

# Optional: a Slack Incoming Webhook URL. If unset, "route to Slack" logs to the
# server console instead (the human-in-the-loop UI is the point, not the send).
SLACK_WEBHOOK_URL=""

# Optional: gate the site behind an access code (so only judges with the code can
# view it). Set this in the deployed (Vercel) environment; share the code in the
# submission. Middleware enforces it on PAGE routes only — API routes (ingest,
# webhooks, cron) stay open so the demo's self-fetch and webhooks never break.
# Leave UNSET for local dev to disable the gate entirely.
SITE_PASSWORD=""
